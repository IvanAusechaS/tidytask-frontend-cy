# =============================================================================
# tidytask-frontend - Variables de entorno de ejemplo
# Copia este archivo como .env.local para desarrollo local
# =============================================================================

# URL base de la API del backend (sin barra al final)
# Desarrollo local: apunta al backend corriendo en localhost
# Produccion (Vercel): configurar en el panel de variables de entorno de Vercel
VITE_API_URL=http://localhost:3001/api

# Entorno de la aplicacion (controla nivel de log del frontend)
# Valores validos: development | production
# En production, los logs DEBUG son suprimidos automaticamente
VITE_APP_ENV=development

# Titulo de la aplicacion
VITE_APP_TITLE=TidyTask

# =============================================================================
# Valores para produccion (Vercel) - NO uses estos valores en .env.local
# VITE_API_URL=https://tidytask-backend-154w.onrender.com/api
# VITE_APP_ENV=production
# =============================================================================

